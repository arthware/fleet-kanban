      ;;
    link)
      # --task-id waits on --linked-task-id (prerequisite). At least one must be in backlog.
      local repo="" a="" b=""
      while [ $# -gt 0 ]; do case "$1" in
        --task-id) a="$2"; shift 2;;
        --linked-task-id) b="$2"; shift 2;;
        --repo) repo="$2"; shift 2;;
        *) echo "task link: unknown flag $1" >&2; return 1;;
      esac; done
      { [ -n "$a" ] && [ -n "$b" ]; } || { echo "usage: fleet task link --task-id <id> --linked-task-id <id> [--repo <name>]" >&2; echo "  --task-id waits on --linked-task-id; when the prerequisite is moved to done the waiter auto-starts" >&2; return 1; }
      local pp; pp="$(_fleet_repo_path "$repo")" || { echo "task link: multiple repos — pass --repo <name>" >&2; return 1; }
      local out; out="$(CLINE_HOME="$CLINE_HOME_DIR" KANBAN_RUNTIME_PORT="$KANBAN_PORT" "$bin" task link --task-id "$a" --linked-task-id "$b" --project-path "$pp" 2>&1 || true)"
      if printf '%s' "$out" | grep -qE '"ok" *: *true|"workspacePath"|"depend'; then say "✓ linked $a → waits on → $b"; else echo "task link failed:" >&2; printf '%s\n' "$out" | head -20 >&2; return 1; fi
      ;;
    unlink)
      local repo="" dep=""
      while [ $# -gt 0 ]; do case "$1" in
        --dependency-id) dep="$2"; shift 2;;
        --repo) repo="$2"; shift 2;;
        *) echo "task unlink: unknown flag $1" >&2; return 1;;
      esac; done
      [ -n "$dep" ] || { echo "usage: fleet task unlink --dependency-id <id> [--repo <name>]   (find the id with: fleet task cat <id>)" >&2; return 1; }
      local pp; pp="$(_fleet_repo_path "$repo")" || { echo "task unlink: multiple repos — pass --repo <name>" >&2; return 1; }
      local out; out="$(CLINE_HOME="$CLINE_HOME_DIR" KANBAN_RUNTIME_PORT="$KANBAN_PORT" "$bin" task unlink --dependency-id "$dep" --project-path "$pp" 2>&1 || true)"
      if printf '%s' "$out" | grep -qE '"ok" *: *true|"workspacePath"'; then say "✓ unlinked dependency $dep"; else echo "task unlink failed:" >&2; printf '%s\n' "$out" | head -20 >&2; return 1; fi
      ;;
    done|move-done)
      # Move a card (or a whole column) to done; cleans its worktree and auto-starts linked cards.
      local repo="" tid="" col=""
      while [ $# -gt 0 ]; do case "$1" in
        --task-id) tid="$2"; shift 2;;
        --column) col="$2"; shift 2;;
        --repo) repo="$2"; shift 2;;
        *) echo "task done: unknown flag $1" >&2; return 1;;
      esac; done
      if { [ -n "$tid" ] && [ -n "$col" ]; } || { [ -z "$tid" ] && [ -z "$col" ]; }; then
        echo "usage: fleet task done (--task-id <id> | --column backlog|in_progress|review|done) [--repo <name>]" >&2; return 1; fi
      local pp; pp="$(_fleet_repo_path "$repo")" || { echo "task done: multiple repos — pass --repo <name>" >&2; return 1; }
      local -a sel; if [ -n "$tid" ]; then sel=(--task-id "$tid"); else sel=(--column "$col"); fi
      local out; out="$(CLINE_HOME="$CLINE_HOME_DIR" KANBAN_RUNTIME_PORT="$KANBAN_PORT" "$bin" task done "${sel[@]}" --project-path "$pp" 2>&1 || true)"
      if printf '%s' "$out" | grep -qE '"ok" *: *true|"workspacePath"'; then say "✓ moved ${tid:-column $col} to done"; else echo "task done failed:" >&2; printf '%s\n' "$out" | head -20 >&2; return 1; fi
      ;;
    delete|rm)
      # Permanently delete a card (or column): removes card, links, and worktree.
      local repo="" tid="" col=""
      while [ $# -gt 0 ]; do case "$1" in
        --task-id) tid="$2"; shift 2;;
        --column) col="$2"; shift 2;;
        --repo) repo="$2"; shift 2;;
        *) echo "task delete: unknown flag $1" >&2; return 1;;
      esac; done
      if { [ -n "$tid" ] && [ -n "$col" ]; } || { [ -z "$tid" ] && [ -z "$col" ]; }; then
        echo "usage: fleet task delete (--task-id <id> | --column <col>) [--repo <name>]   permanently removes cards + worktrees" >&2; return 1; fi
      local pp; pp="$(_fleet_repo_path "$repo")" || { echo "task delete: multiple repos — pass --repo <name>" >&2; return 1; }
      local -a sel; if [ -n "$tid" ]; then sel=(--task-id "$tid"); else sel=(--column "$col"); fi
      local out; out="$(CLINE_HOME="$CLINE_HOME_DIR" KANBAN_RUNTIME_PORT="$KANBAN_PORT" "$bin" task delete "${sel[@]}" --project-path "$pp" 2>&1 || true)"
      if printf '%s' "$out" | grep -qE '"ok" *: *true|"workspacePath"'; then say "✓ deleted ${tid:-column $col}"; else echo "task delete failed:" >&2; printf '%s\n' "$out" | head -20 >&2; return 1; fi
      ;;
    *) echo "usage: fleet task create --prompt <text> [--title <t>] [--repo <name>] [--issue <ref>] [--base-ref <ref>] [--agent claude|codex] [--model <id>] [--plan] [--auto-review commit|pr] [--start]" >&2
       echo "       fleet task update --task-id <id> [--title..][--prompt..|--prompt-file f][--base-ref..][--auto-review commit|pr|off][--agent..][--plan|--no-plan][--cline-model..]" >&2
       echo "       fleet task start  --task-id <id> [--repo <name>]" >&2
       echo "       fleet task say <id> \"<text>\" [--submit|--no-submit] [--repo <name>]   steer a running agent" >&2
       echo "       fleet task link   --task-id <id> --linked-task-id <id> [--repo <name>]   (first waits on second)" >&2
       echo "       fleet task unlink --dependency-id <id> [--repo <name>]" >&2
       echo "       fleet task done   (--task-id <id> | --column <col>) [--repo <name>]" >&2
       echo "       fleet task delete (--task-id <id> | --column <col>) [--repo <name>]   permanent" >&2
       echo "       fleet task ls | list        [--repo <name>] [--column backlog|in_progress|review|done]   (grouped repo -> state)" >&2
       echo "       fleet task cat <id>          one task: state + worktree + diff" >&2
       echo "       fleet task tail <id> [--lines N] [--since <mins>] [--repo <name>]   read a running agent's conversation" >&2
       return 1;;
  esac
}

# Curated, instruction-style tool list for the architect agent. Descriptions say
# WHEN to use each command; this text is injected into the architect's system
# prompt (fleet help --agent), so it IS the tool-wiring. Keep it tight — it costs
# tokens on every architect turn — and list only what the overseer should use.
_fleet_help_agent() {
  cat <<'EOF'
You oversee sub-repositories via the `fleet` CLI. Run these with Bash.

fleet task ls
    Production-line overview: every sub-repo's tasks grouped by repo and by state
    (backlog / in_progress / review / done), each with its agent and session state.
    Run this FIRST and whenever you need to know what work is in flight.

fleet task cat <id>
    Inspect one task in depth — column, agent, session (pid / exit / review reason),
    worktree, branch, and its latest commit diff. Use before you review or steer a task.

fleet task tail <id> [--lines N] [--since <mins>]
    Read the last of a running card's agent conversation — what it's doing right
    now. Use to decide whether a card needs steering (fleet task say) before you act.

fleet task create --prompt <text> --title <t> --repo <name> [--issue <ref>] [--model <id>] [--plan] [--start]
    Dispatch a new unit of work to a sub-repo. Write a scoped prompt (it drives the
    agent's /implement, or /plan with --plan); add --start to launch it now.
    Use --model to run a cheaper agent on mechanical cards (e.g. claude-haiku-4-5)
    and reserve the pricier default for hard design work.
    Use to break a goal into cards and delegate them to coding agents.

fleet task start --task-id <id> --repo <name>
    (Re)launch a task's agent — resume a stopped card or start a created one.

fleet task say <id> "<text>" [--no-submit]
    Answer a question or redirect a running agent. Use when a card is blocked
    (needs-input) or drifting. Submits by default; --no-submit stages the text
    without sending. Only works on a live session — resume an ended card first.

fleet linear [--assigned | --created]
    Read your Linear issues (and which are already started locally). Use to see the
    backlog you can pull work from before creating cards.

fleet initiatives [--issues]
    Active initiatives → projects, ranked by work in progress, with who's on each.
    Use for the strategic view of what matters now.

fleet budget [--json]
    Remaining agent budget per provider — Claude (5-hour + weekly windows via Claude
    Code's OAuth token), Codex (5-hour + weekly, read free from its session rollout),
    and Cursor (monthly included pool + on-demand overage). Each window shows remaining
    %. Check before dispatching heavy work, and back off when the tightest window
    (worst_remaining_percent in --json) runs low.

fleet agent plan <ENG-ID>
    Turn a Linear issue into a design/plan card (validate + design); it lands in Review.
    Use to kick off a well-scoped feature from a Linear ticket.

fleet agent implement <ENG-ID>
    Turn an approved design doc into code + a ship card (build + land end-to-end).
    Use once a plan is reviewed.

fleet xtools [<name> [args]]
    Your own ad-hoc commands. `fleet xtools` lists them; `fleet xtools new <name> [--py]`
    scaffolds an executable stub in the project's .fleet/xtools/ (committed with the repo);
    edit it, then `fleet xtools <name>` runs it with FLEET_DIR/FLEET_CLINE_HOME/
    FLEET_KANBAN_URL/FLEET_KANBAN_PORT exported. Build your own automation when a task
    repeats — a broken tool can't break the core CLI.
EOF
}

# --- xtools: agent-authored ad-hoc automation --------------------------------
# The architect extends the CLI without touching core code: each tool is a
# standalone executable in <project>/.fleet/xtools/ (committed with the project)
# or ~/.config/fleet/xtools/ (shared). `fleet xtools <name> [args]` execs it with
# the board context wired up — FLEET_DIR / FLEET_CLINE_HOME / FLEET_KANBAN_URL /
# FLEET_KANBAN_PORT are exported, and `fleet` itself is on PATH to call back into.
# Isolated by design: a broken tool breaks only itself, never the core CLI.
_xtools_dirs() {  # project dir first (shadows global), then global fallback
  printf '%s\n' "$CFG_DIR/xtools"
  [ "$CFG_DIR" != "$GLOBAL_DIR" ] && printf '%s\n' "$GLOBAL_DIR/xtools"
  return 0
}
_xtools_valid_name() {  # letters/digits/_/-, no leading dash, no path chars
  case "$1" in ''|-*|*[!a-zA-Z0-9_-]*) return 1;; *) return 0;; esac
}
_xtools_find() {  # print path of first matching tool across dirs, or fail
  local d f
  while IFS= read -r d; do f="$d/$1"; [ -f "$f" ] && { printf '%s\n' "$f"; return 0; }; done < <(_xtools_dirs)
  return 1
}
xtools_list() {
  local d f name desc seen=" " found=0
  say "xtools — agent-authored commands (run: fleet xtools <name> [args])"
  while IFS= read -r d; do
    [ -d "$d" ] || continue
    for f in "$d"/*; do
      [ -f "$f" ] || continue
      name="$(basename "$f")"
      case "$seen" in *" $name "*) continue;; esac
      seen="$seen$name "
      desc="$(sed -n 's/^# *desc: *//p' "$f" | head -1)"
      printf '  %-20s %s\n' "$name" "${desc:-}"
      found=1
    done
  done < <(_xtools_dirs)
  [ "$found" = 1 ] || dim "  (none yet — create one: fleet xtools new <name>)"
}
xtools_run() {
  local name="${1:-}"; shift || true
  _xtools_valid_name "$name" || { dim "invalid tool name: '${name}' (letters/digits/_/-)"; return 1; }
  local f; f="$(_xtools_find "$name")" || { dim "no xtool '$name' — list: fleet xtools"; return 1; }
  [ -x "$f" ] || { dim "not executable: $f — chmod +x it"; return 1; }
  FLEET_DIR="$CFG_DIR" FLEET_CLINE_HOME="$CLINE_HOME_DIR" \
  FLEET_KANBAN_URL="$KANBAN_URL" FLEET_KANBAN_PORT="$KANBAN_PORT" \
    exec "$f" "$@"
}
xtools_new() {
  local name="${1:-}" lang="bash"; shift || true
  case "${1:-}" in --py|--python) lang="python";; esac
  _xtools_valid_name "$name" || { dim "usage: fleet xtools new <name> [--py]  (name: letters/digits/_/-)"; return 1; }
  local dir="$CFG_DIR/xtools" f; mkdir -p "$dir"; f="$dir/$name"
  [ -e "$f" ] && { dim "already exists: $f"; return 1; }
  if [ "$lang" = python ]; then
    cat >"$f" <<'PY'
#!/usr/bin/env python3
# desc: <one line — shown in `fleet xtools` listing>
import os, sys

URL = os.environ.get("FLEET_KANBAN_URL", "")
# FLEET_DIR / FLEET_CLINE_HOME / FLEET_KANBAN_PORT are also in os.environ.
# `fleet` is on PATH — shell out to it if useful.

def main(argv):
    print("xtool stub — edit me", argv)

if __name__ == "__main__":
    main(sys.argv[1:])
PY
  else
    cat >"$f" <<'SH'
#!/usr/bin/env bash
# desc: <one line — shown in `fleet xtools` listing>
set -euo pipefail
# FLEET_DIR / FLEET_CLINE_HOME / FLEET_KANBAN_URL / FLEET_KANBAN_PORT are exported.
# `fleet` is on PATH — call back into it if useful.
echo "xtool stub — edit me: $*"
SH
  fi
  chmod +x "$f"
  say "created $f"
  dim "  edit it, then run: fleet xtools $name"
}
xtools_edit() {
  local f; f="$(_xtools_find "${1:-}")" || { dim "no xtool '${1:-}' — create: fleet xtools new ${1:-<name>}"; return 1; }
  "${EDITOR:-vi}" "$f"
}
xtools_rm() {
  local name="${1:-}" f
  _xtools_valid_name "$name" || { dim "invalid name"; return 1; }
  f="$(_xtools_find "$name")" || { dim "no xtool '$name'"; return 1; }
  rm -f "$f" && say "removed $f"
}
fleet_xtools() {
  case "${1:-}" in
    ''|ls|list|-h|--help|help) xtools_list;;
    new|create) shift; xtools_new "$@";;
    path|which) shift; _xtools_find "${1:-}" || { dim "no xtool '${1:-}'"; return 1; };;
    edit) shift; xtools_edit "$@";;
    rm|remove|delete) shift; xtools_rm "$@";;
    *) xtools_run "$@";;
  esac
}

cmd="${1:-status}"; shift || true

# fleet is project-scoped: nearly every command reads/writes a project's .fleet
# (board port, CLINE_HOME, repos). Refuse to run outside one so we never silently
# fall back to the global dir and act on the wrong board. Only project-agnostic
# commands are exempt: create a project, refresh the shared build, or show help.
case "$cmd" in
  init|update|budget|help|-h|--help) ;;
  *) [ "${IN_PROJECT:-0}" = 1 ] || {
       echo "fleet: not inside a fleet project — no .fleet found from $PWD upward." >&2
       echo "       cd into a project (or a subdirectory of one), or run 'fleet init' to create one." >&2
       exit 1
     };;
esac

case "$cmd" in
  help|-h|--help)
    if [ "${1:-}" = "--agent" ]; then _fleet_help_agent
    else grep '^#' "$0" | grep -v '^#!' | sed 's/^# \{0,1\}//' | head -18; fi;;
  status) exec python3 "$DIR/fleet.py" "$@";;
  -*) exec python3 "$DIR/fleet.py" "$cmd" "$@";;   # leading flag -> status view
  new|up|run|ls|rm) exec "$DIR/wt" "$cmd" "$@";;
  linear|mine|tasks)
    case "${1:-}" in
      api-key|--api-key|set-key|key) shift; fleet_set_linear_key "$@";;
      *) exec python3 "$DIR/fleet.py" --mine "$@";;
    esac;;
  agent)
    case "${1:-}" in
      plan|start) shift; exec python3 "$DIR/fleet.py" --agent-plan "$@";;
      implement) shift; exec python3 "$DIR/fleet.py" --agent-implement "$@";;
      *) echo "usage: fleet agent plan|implement <ENG-ID> [--repo NAME] [--agent claude|codex] [--no-start]" >&2; exit 1;;
    esac;;
  initiatives|inits|initiative) exec python3 "$DIR/fleet.py" --initiatives "$@";;
  port) exec "$DIR/port-for" "$@";;
  kanban) fleet_kanban "$@";;
  service|svc) fleet_service "$@";;
  task) fleet_task "$@";;
  xtools|xtool|x) fleet_xtools "$@";;
  init) fleet_init "$@";;
  update) fleet_update "$@";;
  budget|limits|usage) exec python3 "$DIR/budget.py" "$@";;
  *) echo "fleet: unknown command '$cmd' (try: status init update budget new up run ls rm port kanban task xtools)" >&2; exit 1;;
esac

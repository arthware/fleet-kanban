#!/usr/bin/env bash
# fleet — control tower for parallel agent work.
#
#   fleet [status] [args]   epic-grouped overview (worktrees + kanban + Linear)   [default]
#   fleet agent plan <ENG-ID> [--repo N]        Linear issue -> design-doc card (validate + design), lands in Review
#   fleet agent implement <ENG-ID> [--repo N]   design doc -> code + /ship card (build + land end-to-end)
#   fleet linear [--assigned|--created]   your Linear issues (assigned/created), + which are started locally
#   fleet initiatives [--issues] [--all]   active initiatives → projects, sorted by #in-progress, with who's working
#   fleet init [flags]      guided setup: project config, repos, Linear key, kanban
#   fleet update [--repo URL] [--ref BRANCH]   refresh the shared fleet-kanban fork build every project runs from
#   fleet new  <branch>     create a runnable worktree (-> wt new)
#   fleet up   [dir]        prepare/adopt a worktree (-> wt up)
#   fleet run  [-- args]    start the app on this worktree's port (-> wt run)
#   fleet ls                worktrees + ports + live state (-> wt ls)
#   fleet rm   [dir]        remove a worktree + free its port (-> wt rm)
#   fleet port [args]       stable per-worktree port (-> port-for)
#   fleet kanban [install|start|stop|restart|sync|status|open]   fleet-managed kanban server (sync = register configured repos as projects)
#   fleet service [start|stop|status]       run the board under launchd (survives terminal/session death)
#   fleet kanban daemon [install|uninstall|status]          DEPRECATED synonym for `fleet service`
#   fleet xtools [<name> [args] | new <name> [--py] | ls | edit <name> | rm <name>]   agent-authored ad-hoc commands
set -euo pipefail
# resolve through symlinks so DIR is the real tools/fleet dir, not ~/.local/bin
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  D="$(cd -P "$(dirname "$SOURCE")" && pwd)"; SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$D/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

GLOBAL_DIR="$HOME/.config/fleet"         # shared: vendored kanban binary, key fallback
# the project's .fleet dir, found by walking up from CWD (like .git); global if none
_fleet_dir() {
  [ -n "${FLEET_DIR:-}" ] && { echo "$FLEET_DIR"; return 0; }
  local d="$PWD"
  while [ "$d" != "/" ]; do [ -d "$d/.fleet" ] && { echo "$d/.fleet"; return 0; }; d="$(dirname "$d")"; done
  return 1
}
# IN_PROJECT=1 only when a real project .fleet was found by walking up from CWD.
# Falling back to GLOBAL_DIR is for shared assets (vendor/src), NOT an implicit
# project — project-scoped commands refuse to run outside a project (see dispatch).
if CFG_DIR="$(_fleet_dir)"; then IN_PROJECT=1; else CFG_DIR="$GLOBAL_DIR"; IN_PROJECT=0; fi
KEYFILE="$CFG_DIR/linear.key"
KANBAN_VENDOR="$GLOBAL_DIR/vendor"       # binary is shared across projects (npm stable)
KANBAN_SRC_VENDOR="$GLOBAL_DIR/src"      # shared fork build (fleet update) — one checkout all
                                         # consumer projects run from; honors CLINE_HOME (npm one doesn't)
# per-project source build (dogfood): our fork checkout, run straight from dist/cli.js.
# Recorded in the project's .fleet/config.json so it applies to THIS project only,
# leaving other projects on the shared stable vendor.
KANBAN_SOURCE="${KANBAN_SOURCE:-$( [ -f "$CFG_DIR/config.json" ] && python3 -c "import json;print(json.load(open('$CFG_DIR/config.json')).get('kanban_source',''))" 2>/dev/null || echo '' )}"
KANBAN_LOG="$CFG_DIR/kanban.log"
KANBAN_PORT="${KANBAN_PORT:-$( [ -f "$CFG_DIR/config.json" ] && python3 -c "import json;print(json.load(open('$CFG_DIR/config.json')).get('kanban_port',3484))" 2>/dev/null || echo 3484 )}"
KANBAN_URL="${KANBAN_URL:-http://127.0.0.1:$KANBAN_PORT}"
# Isolated, project-local cline home (board/worktrees/settings live under the
# project, not $HOME) — only inside a real project. The forked fleet-kanban honors
# CLINE_HOME; the stable vendor build ignores it (harmless), so other projects on
# the stable build keep using ~/.cline. Empty => fork falls back to ~/.cline.
if [ "$CFG_DIR" != "$GLOBAL_DIR" ]; then CLINE_HOME_DIR="$CFG_DIR/cline"; else CLINE_HOME_DIR=""; fi

# Silence Node process warnings (e.g. the DEP0205 module.register() deprecation the
# kanban CLI prints on stderr). We capture bin output with 2>&1 and json.loads it —
# a warning line prefixing the JSON breaks the parse (tail fell back to a raw dump).
export NODE_NO_WARNINGS=1

say() { printf '\033[1m%s\033[0m\n' "$*"; }
dim() { printf '\033[2m%s\033[0m\n' "$*"; }

fleet_set_linear_key() {
  local key="${1:-}"
  [ -n "$key" ] || { echo "usage: fleet linear api-key <apiKey>" >&2; return 1; }
  mkdir -p "$CFG_DIR"
  ( umask 177; printf '%s' "$key" > "$KEYFILE" ); chmod 600 "$KEYFILE"
  say "stored Linear key at $KEYFILE (chmod 600)"
  if curl -fsS --max-time 8 -H "Authorization: $key" -H "Content-Type: application/json" \
      -d '{"query":"{ viewer { name } }"}' https://api.linear.app/graphql 2>/dev/null | grep -q '"name"'; then
    say "✓ key works"
  else
    dim "⚠ could not validate — check the key (should start with lin_api_)"
  fi
}

# --- kanban binary that fleet owns (no reliance on npx cache paths) ----------
kanban_bin() {
  # 1) this project's source build (fork dogfood working copy) — dist/cli.js is chmod +x w/ node shebang
  if [ -n "$KANBAN_SOURCE" ] && [ -x "$KANBAN_SOURCE/dist/cli.js" ]; then echo "$KANBAN_SOURCE/dist/cli.js"; return 0; fi
  # 2) shared fork build (fleet update) — honors CLINE_HOME, so consumer projects get board isolation
  if [ -x "$KANBAN_SRC_VENDOR/dist/cli.js" ]; then echo "$KANBAN_SRC_VENDOR/dist/cli.js"; return 0; fi
  # 3) shared vendored npm build (stable cline/kanban; ignores CLINE_HOME)
  if [ -x "$KANBAN_VENDOR/node_modules/.bin/kanban" ]; then echo "$KANBAN_VENDOR/node_modules/.bin/kanban"; return 0; fi
  command -v kanban 2>/dev/null && return 0
  return 1
}

kanban_running() { curl -fsS --max-time 3 "$KANBAN_URL/api/trpc/projects.list" >/dev/null 2>&1; }

kanban_install() {
  # --source <checkout>: build our fork and run this project from it (dogfood)
  if [ "${1:-}" = "--source" ]; then
    local src="${2:-}"; [ -n "$src" ] || { echo "usage: fleet kanban install --source <checkout>" >&2; return 1; }
    src="${src/#\~/$HOME}"; src="$(cd "$src" 2>/dev/null && pwd)" || { dim "no such dir: $2"; return 1; }
    [ -f "$CFG_DIR/config.json" ] || { dim "no project .fleet — run 'fleet init' first"; return 1; }
    say "building fleet-kanban from source: $src"
    ( cd "$src" && npm run install:all && npm run build ) || { dim "source build failed"; return 1; }
    [ -x "$src/dist/cli.js" ] || { dim "build produced no dist/cli.js"; return 1; }
    SRC="$src" python3 - "$CFG_DIR/config.json" <<'PY'
import json, os, sys
f = sys.argv[1]; d = json.load(open(f)); d["kanban_source"] = os.environ["SRC"]
json.dump(d, open(f, "w"), indent=2); print("→ recorded kanban_source (this project only):", os.environ["SRC"])
PY
    say "✓ $("$src/dist/cli.js" --version 2>/dev/null || echo built) — start with: fleet kanban start"
    return 0
  fi
  local ver="${1:-latest}"
  mkdir -p "$KANBAN_VENDOR"
  [ -f "$KANBAN_VENDOR/package.json" ] || ( cd "$KANBAN_VENDOR" && npm init -y >/dev/null 2>&1 )
  say "installing kanban@$ver into $KANBAN_VENDOR …"
  ( cd "$KANBAN_VENDOR" && npm install "kanban@$ver" --no-fund --no-audit ) || { dim "npm install failed"; return 1; }
  say "✓ $("$KANBAN_VENDOR/node_modules/.bin/kanban" --version 2>/dev/null || echo installed)"
}

_kanban_url_banner() {
  say "→ Open: $KANBAN_URL"
  dim "  (use 127.0.0.1, NOT localhost — some focus/blocker extensions block the localhost hostname)"
}

# Register the project's configured repos as kanban projects so the board is never
# empty on a fresh start. Idempotent — skips repos already on the board. Requires a
# running server (registration is a tRPC call); a no-op if none is configured.
kanban_sync_projects() {
  [ -f "$CFG_DIR/config.json" ] || return 0
  kanban_running || return 0
  local root; root="$(dirname "$CFG_DIR")"
  ROOT="$root" URL="$KANBAN_URL" HOME_DIR="$HOME" python3 - "$CFG_DIR/config.json" <<'PY'
import json, os, sys, urllib.request
cfg = json.load(open(sys.argv[1]))
root, url, home = os.environ["ROOT"], os.environ["URL"], os.environ["HOME_DIR"]
# resolve each configured repo (basename or absolute) to an absolute path under the project
wanted, seen = [], set()
# Register the project root itself when it's a git repo. It contains the work
# repos, so the board detects it as the ARCHITECT workspace — its agent starts at
# the root and can reach every sub-repo (see `fleet init` git-init below).
if os.path.isdir(os.path.join(root, ".git")):
    rp = os.path.realpath(root)
    seen.add(rp); wanted.append(rp)
for r in cfg.get("repos", []) or []:
    p = os.path.realpath(r if os.path.isabs(r) else os.path.join(root, r))
    if os.path.isdir(p) and p not in seen:
        seen.add(p); wanted.append(p)
if not wanted:
    sys.exit(0)
try:
    with urllib.request.urlopen(f"{url}/api/trpc/projects.list", timeout=8) as resp:
        have = {os.path.realpath(p["path"]) for p in json.load(resp)["result"]["data"]["projects"]}
except Exception as e:
    print(f"  (could not read projects.list: {e})"); sys.exit(0)
added = 0
for p in wanted:
    if p in have:
        continue
    req = urllib.request.Request(f"{url}/api/trpc/projects.add",
                                 data=json.dumps({"path": p}).encode(),
                                 headers={"Content-Type": "application/json"}, method="POST")
    try:
        with urllib.request.urlopen(req, timeout=20) as resp:
            out = json.load(resp)["result"]["data"]
        if out.get("ok"):
            print(f"  + project: {p.replace(home, '~')}"); added += 1
        else:
            print(f"  ! {os.path.basename(p)}: {out.get('error') or 'add failed'}")
    except Exception as e:
        print(f"  ! {os.path.basename(p)}: {e}")
if added == 0:
    print(f"  {len(wanted)} project(s) already registered")
PY
}

kanban_start() {
  local dir="${1:-$PWD}"
  kanban_running && { say "already running"; kanban_sync_projects; _kanban_url_banner; return 0; }
  local bin; bin="$(kanban_bin)" || { dim "kanban not installed — run: fleet kanban install"; return 1; }
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || dir="$HOME"
  [ -n "$CLINE_HOME_DIR" ] && { mkdir -p "$CLINE_HOME_DIR"; dim "  state: $CLINE_HOME_DIR (isolated)"; }
  say "starting kanban (port $KANBAN_PORT) from $dir …"
  # --skip-shutdown-cleanup: on stop, do NOT move cards to Done or delete worktrees
  # (kanban's cleanup path is what wedged the port + jumped cards to Done; column is
  # meant to derive from git — see epic §4.4).
  ( cd "$dir" && CLINE_HOME="$CLINE_HOME_DIR" nohup "$bin" --port "$KANBAN_PORT" --no-open --skip-shutdown-cleanup >"$KANBAN_LOG" 2>&1 & )
  for i in $(seq 1 30); do kanban_running && { say "✓ up"; kanban_sync_projects; _kanban_url_banner; return 0; }; sleep 1; done
  dim "did not come up in 30s — see $KANBAN_LOG"; return 1
}

# robust stop / unstick: kill the server's child agent sessions FIRST (they wedge
# kanban's own cleanup and leak the port), then TERM the server, then -9 if it clings.
kanban_stop() {
  local srv; srv="$(lsof -tiTCP:"$KANBAN_PORT" -sTCP:LISTEN -P 2>/dev/null)"
  [ -n "$srv" ] || { dim "not running"; return 0; }
  local kids; kids="$(pgrep -P "$srv" 2>/dev/null)"
  # also sweep any sidebar/agent claude procs kanban spawned (they block shutdown)
  local strays; strays="$(pgrep -f "$HOME/.cline/kanban/hooks|/.cline/worktrees/" 2>/dev/null)"
  [ -n "$kids$strays" ] && kill -TERM $kids $strays 2>/dev/null
  kill -TERM $srv 2>/dev/null
  local i; for i in 1 2 3 4 5; do kanban_running || break; sleep 1; done
  if kanban_running; then
    say "server wedged on shutdown — forcing"
    kill -9 $srv $kids $strays 2>/dev/null
    pgrep -f "$HOME/.cline/kanban/hooks" 2>/dev/null | xargs kill -9 2>/dev/null
    sleep 1
  fi
  kanban_running && { dim "still bound on :$KANBAN_PORT — check: lsof -iTCP:$KANBAN_PORT"; return 1; } || say "stopped"
}

kanban_status() {
  if kanban_running; then
    say "kanban running at $KANBAN_URL"
    curl -s "$KANBAN_URL/api/trpc/projects.list" | python3 -c "import sys,json;ps=json.load(sys.stdin)['result']['data']['projects'];print(f'  {len(ps)} projects:');[print('   ',p['id'],'->',p['path'].replace('$HOME','~')) for p in ps]" 2>/dev/null
  else
    dim "kanban not running (port $KANBAN_PORT)"; echo "  start it:  fleet kanban start"
    kanban_bin >/dev/null || echo "  (not installed yet:  fleet kanban install)"
  fi
}

# --- launchd daemon: parent is the OS, not your terminal ---------------------
# Fixes "kanban died with the parent process": under launchd the server is not a
# child of the launching shell, so closing the terminal / ending a session can't
# signal it. KeepAlive (unconditional) keeps it up: launchd revives it on ANY exit,
# including a raw kill, so only `fleet service stop` truly stops it.
_kanban_label() { echo "com.fleet.kanban.$(basename "$(dirname "$CFG_DIR")")"; }
_kanban_plist() { echo "$HOME/Library/LaunchAgents/$(_kanban_label).plist"; }

kanban_daemon() {
  local sub="${1:-install}"; local label plist; label="$(_kanban_label)"; plist="$(_kanban_plist)"
  case "$sub" in
    install|load|on)
      local bin node dir; bin="$(kanban_bin)" || { dim "kanban not installed — run: fleet kanban install"; return 1; }
      node="$(command -v node)" || { dim "node not found on PATH"; return 1; }
      # Board cwd must be the repo whose workspace holds the cards (kanban_source when
      # configured) — NOT the fleet project dir, else the server spins up an empty
      # workspace named after the project root. Fall back to $PWD for source-less setups.
      dir="${KANBAN_SOURCE:-$PWD}"; git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || dir="$HOME"
      kanban_stop >/dev/null 2>&1 || true      # clear any terminal-bound instance first
      [ -n "$CLINE_HOME_DIR" ] && mkdir -p "$CLINE_HOME_DIR"
      mkdir -p "$(dirname "$plist")"
      LABEL="$label" NODE="$node" BIN="$bin" PORT="$KANBAN_PORT" WDIR="$dir" LOG="$KANBAN_LOG" \
        CHOME="$CLINE_HOME_DIR" \
        PATHVAL="$(dirname "$node"):$HOME/.asdf/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin" \
        python3 - "$plist" <<'PY'
import os, plistlib, sys
env = {"PATH": os.environ["PATHVAL"]}
chome = os.environ.get("CHOME", "").strip()
if chome: env["CLINE_HOME"] = chome     # isolate board/worktrees/settings to the project
p = {
  "Label": os.environ["LABEL"],
  "ProgramArguments": [os.environ["NODE"], os.environ["BIN"], "--port", os.environ["PORT"], "--no-open", "--skip-shutdown-cleanup"],
  "WorkingDirectory": os.environ["WDIR"],
  "RunAtLoad": True,
  "KeepAlive": True,
  "StandardOutPath": os.environ["LOG"],
  "StandardErrorPath": os.environ["LOG"],
  "EnvironmentVariables": env,
}
with open(sys.argv[1], "wb") as f: plistlib.dump(p, f)
print("→ wrote", sys.argv[1])
PY
      launchctl unload "$plist" 2>/dev/null || true
      launchctl load -w "$plist" 2>/dev/null || { dim "launchctl load failed"; return 1; }
      say "daemon '$label' loaded (port $KANBAN_PORT, dir $dir)"
      local i; for i in $(seq 1 30); do kanban_running && { say "✓ up"; kanban_sync_projects; _kanban_url_banner; return 0; }; sleep 1; done
      dim "loaded but not up in 30s — see $KANBAN_LOG"; return 1;;
    uninstall|unload|off)
      launchctl unload "$plist" 2>/dev/null || true
      [ -f "$plist" ] && rm -f "$plist" && say "daemon '$label' removed" || dim "no daemon installed"
      kanban_stop >/dev/null 2>&1 || true;;
    status)
      if launchctl list 2>/dev/null | grep -q "$label"; then say "daemon '$label' loaded"; else dim "no daemon (run: fleet service start)"; fi
      kanban_status;;
    *) echo "usage: fleet kanban daemon [install|uninstall|status]" >&2; return 1;;
  esac
}

# --- killswitch: protect the live (launchd-daemon) board -----------------------
# The daemon board is the live one that hosts every card + agent session. An agent's
# own verify/test step must never be able to stop it. `fleet kanban stop` refuses to
# touch a daemon board unless --force; and a daemon board's `restart` reloads the
# daemon (supervised) instead of stop+start (which would un-daemonize it). Raw kills
# are separately covered by the daemon's KeepAlive auto-revive.
_kanban_daemon_loaded() { launchctl list 2>/dev/null | grep -q "$(_kanban_label)"; }

kanban_guarded_stop() {
  local force=""; case "${1:-}" in --force|-f|--yes|-y) force=1;; esac
  if _kanban_daemon_loaded && [ -z "$force" ]; then
    say "refusing: this board runs under the launchd daemon (protected)."
    dim "  it auto-revives if killed. to really stop it:  fleet service stop"
    dim "  to override anyway:                            fleet kanban stop --force"
    return 1
  fi
  if [ -n "$force" ] && _kanban_daemon_loaded; then kanban_daemon uninstall; else kanban_stop; fi
}

kanban_guarded_restart() {
  if _kanban_daemon_loaded; then
    say "reloading the launchd daemon (protected board) with the current build…"
    kanban_daemon install; return $?
  fi
  kanban_stop; kanban_start "$@"
}

fleet_kanban() {
  case "${1:-status}" in
    install)        shift; kanban_install "$@";;
    start)          shift; kanban_start "$@";;
    stop)           shift; kanban_guarded_stop "$@";;
    restart)        shift; kanban_guarded_restart "$@";;
    daemon)         shift
                    dim "note: 'fleet kanban daemon' is deprecated — use 'fleet service {start|stop|status}'"
                    kanban_daemon "$@";;
    sync)           kanban_running || { dim "not running — start it: fleet kanban start"; return 1; }; say "syncing projects → $KANBAN_URL"; kanban_sync_projects;;
    open)           kanban_running || kanban_start; command -v open >/dev/null && open "$KANBAN_URL";;
    status|"")      kanban_status;;
    *) echo "usage: fleet kanban [install|start|stop|restart|daemon|sync|open|status]" >&2; return 1;;
  esac
}

# service = the persistent (launchd) board lifecycle, clearly named. Thin front over the
# daemon plumbing above. `fleet service start|stop|status`. Supersedes `fleet kanban daemon …`.
fleet_service() {
  case "${1:-status}" in
    start|up|on)     kanban_daemon install;;
    stop|down|off)   kanban_daemon uninstall;;
    restart|reload)  kanban_daemon install;;      # install = unload+load = reload
    status|"")       kanban_daemon status;;
    *) echo "usage: fleet service [start|stop|status]" >&2; return 1;;
  esac
}

# --- shared fork build: one checkout every consumer project runs from --------
# Keeps a single clone of the fleet-kanban fork at $GLOBAL_DIR/src, tracking main,
# and rebuilds it. Consumer projects (non-dogfood) fall through to it in kanban_bin
# (tier 2) and pick up the new build on their next `fleet kanban start`. Dogfood
# (tools/) overrides this with its own working-copy kanban_source and is untouched.
fleet_update() {
  local repo="" ref="main"
  while [ $# -gt 0 ]; do case "$1" in
    --repo) repo="$2"; shift 2;;
    --ref|--branch) ref="$2"; shift 2;;
    -h|--help) echo "usage: fleet update [--repo <git-url>] [--ref <branch>]  (refresh the shared fleet-kanban build)"; return 0;;
    *) echo "fleet update: unknown flag $1" >&2; return 1;;
  esac; done
  local dst="$KANBAN_SRC_VENDOR"
  if [ -d "$dst/.git" ]; then
    say "updating shared fleet-kanban build → $dst ($ref)"
    git -C "$dst" fetch origin "$ref" || { dim "fetch failed"; return 1; }
    git -C "$dst" checkout "$ref" >/dev/null 2>&1 || true
    git -C "$dst" reset --hard "origin/$ref" || { dim "reset --hard origin/$ref failed"; return 1; }
  else
    # Discover the fork URL without hardcoding it: explicit --repo, else the
    # origin of the dogfood working-copy checkout that ships next to this CLI.
    [ -n "$repo" ] || repo="$(git -C "$DIR/../fleet-kanban" remote get-url origin 2>/dev/null || true)"
    [ -n "$repo" ] || { dim "no source repo found — pass it: fleet update --repo <git-url>"; return 1; }
    say "cloning fleet-kanban ($ref) → $dst"
    mkdir -p "$(dirname "$dst")"
    git clone --branch "$ref" "$repo" "$dst" || { dim "clone failed"; return 1; }
  fi
  say "building (npm run install:all && npm run build) …"
  ( cd "$dst" && npm run install:all && npm run build ) || { dim "build failed"; return 1; }
  [ -x "$dst/dist/cli.js" ] || { dim "build produced no dist/cli.js"; return 1; }
  say "✓ shared fleet-kanban ready at $dst"
  dim "  consumer projects use it on their next 'fleet kanban start' (dogfood keeps its own source override)"
}

# Make the project root a thin git repo so the board registers it as the architect
# workspace (a workspace whose path contains the others is detected as the architect).
# No-op if it's already a repo — never touch an existing one. Nested work repos and
# board state are gitignored; only the guide docs are tracked, with one initial commit
# so the workspace has a valid HEAD.
_init_root_repo() {
  local dir="$1"; shift
  git -C "$dir" rev-parse --git-dir >/dev/null 2>&1 && return 0
  say "  git-init'ing project root → architect workspace ($dir)"
  git -C "$dir" init -q
  if [ ! -e "$dir/.gitignore" ]; then
    { printf '# fleet workspace root — nested work repos and board state are not tracked here\n'
      printf '.fleet/\n.DS_Store\n'
      local r; for r in "$@"; do [ -n "$r" ] && printf '%s/\n' "$r"; done
    } > "$dir/.gitignore"
  fi
  git -C "$dir" add -A >/dev/null 2>&1 || true
  git -C "$dir" -c user.name=fleet -c user.email=fleet@localhost \
      commit -q -m "chore: initialize fleet workspace" >/dev/null 2>&1 || true
}

# Scaffold a starter AGENTS.md + CLAUDE.md into a fresh project (never clobbers an
# existing file). Generic template — the project's own name/port/repos are filled in.
_scaffold_agent_docs() {
  local dir="$1" pname="$2" pport="$3" repomd="$4"
  if [ ! -e "$dir/AGENTS.md" ]; then
    cat >"$dir/AGENTS.md" <<EOF
# $pname — fleet-managed board

Coding work on this project runs as agent sessions on a **fleet-kanban** board. Author and observe
that work with the \`fleet\` CLI, run **from inside this directory** (fleet is project-scoped).

## The live board — do not disrupt it
- The board runs on **port $pport** (\`fleet kanban status\` to check, \`fleet kanban open\` to view).
- **Never stop, kill, or restart the live board while a card is running.** You may yourself be a card
  on it — stopping it cuts your own session. Observe with \`fleet task ls\` / \`fleet task cat <id>\`,
  never \`fleet kanban stop|restart\`.

## Observe / drive the board
- \`fleet task ls\`         — all cards, grouped by repo → column
- \`fleet task cat <id>\`   — full detail for one card (session, worktree, branch, commit)
- \`fleet kanban status\`   — is the board up, which repos are registered

## Repos on this board
$repomd
## Rules
- **Never commit or push unless asked.**
- Prefer the \`fleet\` CLI for observing state; inspect raw files only when the CLI looks wrong.
EOF

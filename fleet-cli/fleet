fleet_init() {
  local root="$PWD" name="" team="ENG" key="" port="3484" yes="" force=""
  while [ $# -gt 0 ]; do case "$1" in
    --name) name="$2"; shift 2;;
    --dir|--root) root="$2"; shift 2;;
    --linear-team) team="$2"; shift 2;;
    --linear-key) key="$2"; shift 2;;
    --port) port="$2"; shift 2;;
    --force) force=1; shift;;
    --yes|-y) yes=1; shift;;
    *) echo "init: unknown flag $1" >&2; return 1;;
  esac; done
  root="${root/#\~/$HOME}"; root="$(cd "$root" && pwd)"
  [ -z "$name" ] && name="$(basename "$root")"
  local fdir="$root/.fleet"

  # Never clobber an existing project config — re-running init should be safe.
  # Print the current config and bail; use --force (or edit the file) to change it.
  if [ -f "$fdir/config.json" ] && [ -z "$force" ]; then
    say "fleet project already initialized → $fdir/config.json"
    cat "$fdir/config.json"
    dim "(unchanged — edit the file directly, or re-run with --force to overwrite)"
    return 0
  fi

  mkdir -p "$fdir"
  printf '*\n' > "$fdir/.gitignore"       # never commit .fleet (holds the Linear key)

  say "Initializing fleet project '$name' → $fdir"
  # auto-detect repos = immediate subdirs that are git repos
  local repos=() d
  for d in "$root"/*/; do
    [ -d "$d" ] || continue
    if git -C "$d" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      repos+=("$(basename "$d")"); dim "  repo: $(basename "$d")"
    fi
  done
  [ ${#repos[@]} -eq 0 ] && dim "  (no git repos directly under $root yet — clone some, then re-run)"

  NAME="$name" TEAM="$team" PORT="$port" REPOS="${repos[*]:-}" python3 - "$fdir/config.json" <<'PY'
import json, os, sys
json.dump({"name": os.environ["NAME"], "linear_team": os.environ["TEAM"],
          "kanban_port": int(os.environ["PORT"]),
          "repos": os.environ.get("REPOS", "").split()}, open(sys.argv[1], "w"), indent=2)
print("→ wrote", sys.argv[1])
PY

  if [ -n "$key" ]; then
    ( umask 177; printf '%s' "$key" > "$fdir/linear.key" ); chmod 600 "$fdir/linear.key"
    say "stored Linear key in $fdir/linear.key (chmod 600)"
  fi

  # Scaffold starter agent docs (AGENTS.md + CLAUDE.md) so sessions on this board
  # get project context and the "don't kill the live board" guardrail for free.
  local repomd="" r
  for r in "${repos[@]:-}"; do [ -n "$r" ] && repomd="${repomd}- ${r}"$'\n'; done
  [ -n "$repomd" ] || repomd="- (none yet — clone repos under this dir, then re-run 'fleet init')"$'\n'
  _scaffold_agent_docs "$root" "$name" "$port" "$repomd"

  # Make the root a thin git repo so it registers as the ARCHITECT workspace — the
  # board's agent then starts at the project root and can reach every sub-repo,
  # instead of being scoped to one repo. Only when the root isn't already a repo.
  _init_root_repo "$root" "${repos[@]:-}"

  # Prefer the shared fork build (isolated, honors CLINE_HOME). Only nudge — the
  # build is a one-time global step, and auto-fetching the npm binary here would
  # silently hand back a board that ignores this project's CLINE_HOME.
  local need_build=""
  kanban_bin >/dev/null || need_build=1

  # If a board is already up, register the detected repos now; otherwise they'll be
  # registered automatically on the next `fleet kanban start`.
  kanban_running && { echo; say "registering repos on the running board…"; kanban_sync_projects; }

  echo; say "Done. From inside $root:"
  echo "  fleet                 # overview for this project (${#repos[@]} repos)"
  if [ -n "$need_build" ]; then
    echo "  fleet update          # one-time: clone + build the shared fleet-kanban fork (isolated board)"
    dim  "                        (or 'fleet kanban install' for the stable npm build — does NOT isolate CLINE_HOME)"
  fi
  echo "  fleet kanban start    # boot the board on port $port"
  echo "  fleet new <branch>    # runnable worktree on its own port"
}

# --- ad-hoc kanban cards on THIS project's board (isolated env + source build) ---
# Resolve a configured repo to an absolute path. $1 = optional repo name; with no
# name, succeeds only when the project has exactly one repo (else ambiguous -> 1).
_fleet_repo_path() {
  local want="$1" root; root="$(dirname "$CFG_DIR")"
  if [ -n "$want" ]; then echo "$root/$want"; return 0; fi
  local repos; repos="$(python3 -c "import json;print('\n'.join(json.load(open('$CFG_DIR/config.json')).get('repos',[])))" 2>/dev/null)"
  [ "$(printf '%s\n' "$repos" | grep -c .)" = "1" ] || return 1
  echo "$root/$(printf '%s\n' "$repos" | head -1)"
}


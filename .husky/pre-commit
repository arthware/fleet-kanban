#!/bin/sh

# The live board leaks KANBAN_RUNTIME_PORT (e.g. 3500) into every session it spawns.
# Runtime tests assert against the default port (3484), so an inherited value makes the
# pre-commit test suite fail for any agent the board launched. Scrub it so the checks
# always run on a clean env regardless of which board launched this shell.
unset KANBAN_RUNTIME_PORT

STAGED_FILES=$(git diff --cached --name-only)

echo "Running biome check on staged files..."
npx biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true
if [ $? -ne 0 ]; then
	echo "Biome check failed."
	exit 1
fi

echo "Running type checking and fast tests..."
npm run typecheck && npm run test:precommit
if [ $? -ne 0 ]; then
	echo "Checks failed."
	exit 1
fi

for file in $STAGED_FILES; do
	if [ -f "$file" ]; then
		git add "$file"
	fi
done

echo "Pre-commit checks passed."
